{
  "name": "Workflow B — Campaign surge webhook",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "surge",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "surge-webhook",
      "name": "Surge webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "surge"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/repos/{{ $env.GITHUB_REPO_OWNER }}/{{ $env.GITHUB_REPO_NAME }}/actions/workflows/monitor.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "ref", "value": "main" },
            {
              "name": "inputs",
              "value": "={{ JSON.stringify({ mode: 'surge', regions: 'us-east,eu-west,ap-southeast,sa-east,me-south,af-south' }) }}"
            }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "text" } }
        }
      },
      "id": "dispatch-surge",
      "name": "Dispatch surge run",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300],
      "credentials": {
        "httpHeaderAuth": { "id": "github-pat", "name": "GitHub PAT" }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"triggered\": true }",
        "options": {}
      },
      "id": "respond",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [680, 300]
    }
  ],
  "connections": {
    "Surge webhook": {
      "main": [[{ "node": "Dispatch surge run", "type": "main", "index": 0 }]]
    },
    "Dispatch surge run": {
      "main": [[{ "node": "Respond", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" }
}
