  {
    "name": "Workflow C — Stats + alerting (Discord)",
    "nodes": [
      {
        "parameters": { "rule": { "interval": [{ "field": "minutes", "minutesInterval": 30 }] } },
        "id": "alert-schedule", "name": "Alert schedule",
        "type": "n8n-nodes-base.scheduleTrigger", "typeVersion": 1, "position": [240, 300]
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  COUNT(*) FILTER (WHERE status = 1) AS ok_count,\n  COUNT(*) FILTER (WHERE status = 0) AS failure_count,\n  COUNT(*) AS total_count,\n  ROUND(AVG(ttfb_ms)::numeric, 0) AS avg_ttfb,\n  MAX(checked_at) AS last_seen,\n  COUNT(*) FILTER (WHERE mode = 'surge') AS surge_count,\n  json_agg(json_build_object('region', region, 'ok', CASE WHEN status=1 THEN true ELSE false END, 'ttfb', ttfb_ms, 'colo', cf_colo) ORDER BY checked_at DESC) FILTER (WHERE checked_at > now() - interval '30 minutes') AS recent\nFROM monitor_results\nWHERE checked_at > now() - interval '30 minutes'",
          "options": {}
        },
        "id": "check-status", "name": "Check status",
        "type": "n8n-nodes-base.postgres", "typeVersion": 2, "position": [460, 300],
        "credentials": { "postgres": { "id": "feCyf8b8GoMyHCPS", "name": "Postgres GamersLab" } }
      },
      {
        "parameters": {
          "jsCode": "const row = $input.first().json;\nconst failures = parseInt(row.failure_count) || 0;\nconst ok = parseInt(row.ok_count) || 0;\nconst total = parseInt(row.total_count) || 0;\nconst avgTtfb = parseInt(row.avg_ttfb) || 0;\nconst lastSeen = row.last_seen ? new Date(row.last_seen).toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit', timeZone: 'Australia/Melbourne' }) : 'n/a';\nconst surgeCount = parseInt(row.surge_count) || 0;\n\n// Pipeline dead\nif (total === 0) {\n  return [{ json: { message: '💀 **Monitor pipeline is down**\\n\\nNo results in the last 30 minutes. GitHub Actions may have stopped.\\n\\nhttps://github.com/DeveloperAlly/gamerslab/actions' } }];\n}\n\n// Build per-region summary from recent runs\nconst recent = row.recent || [];\nconst byRegion = {};\nfor (const r of recent) {\n  if (!byRegion[r.region]) byRegion[r.region] = { ok: 0, fail: 0, ttfbs: [] };\n  r.ok ? byRegion[r.region].ok++ : byRegion[r.region].fail++;\n  if (r.ttfb) byRegion[r.region].ttfbs.push(r.ttfb);\n}\n\nconst regionLines = Object.entries(byRegion).map(([reg, d]) => {\n  const tot = d.ok + d.fail;\n  const pct = tot ? Math.round(d.ok / tot * 100) : 0;\n  const avg = d.ttfbs.length ? Math.round(d.ttfbs.reduce((a,b)=>a+b,0)/d.ttfbs.length) : 0;\n  const icon = pct === 100 ? '🟢' : pct >= 80 ? '🟡' : '🔴';\n  return `${icon} ${reg} — ${pct}% uptime · ${avg}ms avg`;\n}).join('\\n');\n\nconst statusIcon = failures === 0 ? '✅' : failures < 3 ? '⚠️' : '🚨';\nconst header = `${statusIcon} **GamersLab Monitor — 30 min report**`;\nconst summary = `**Checks:** ${ok}/${total} passed · **Avg TTFB:** ${avgTtfb}ms · **Last run:** ${lastSeen}${surgeCount > 0 ? ` · **Surge runs:** ${surgeCount}` : ''}`;\nconst failLine = failures > 0 ? `\\n⚠️ **${failures} failures detected**` : '';\n\nreturn [{ json: { message: `${header}\\n${summary}${failLine}\\n\\n${regionLines}` } }];"
        },
        "id": "evaluate-status", "name": "Build report",
        "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [680, 300]
      },
      {
        "parameters": {
          "resource": "message",
          "guildId": { "__rl": true, "value": "1066890817425387581", "mode": "id" },
          "channelId": { "__rl": true, "value": "1514424075282550916", "mode": "list", "cachedResultName": "gamers-lab-monitor" },
          "content": "={{ $json.message }}",
          "options": {}
        },
        "id": "discord-alert", "name": "Send report",
        "type": "n8n-nodes-base.discord", "typeVersion": 2, "position": [900, 300],
        "credentials": { "discordBotApi": { "id": "TjYM6pZNQ2PGSVmG", "name": "Discord Bot GamersLab" } }
      }
    ],
    "connections": {
      "Alert schedule": { "main": [[{ "node": "Check status", "type": "main", "index": 0 }]] },
      "Check status": { "main": [[{ "node": "Build report", "type": "main", "index": 0 }]] },
      "Build report": { "main": [[{ "node": "Send report", "type": "main", "index": 0 }]] }
    },
    "settings": { "executionOrder": "v1" }
  },
  {
    "name": "Workflow D — Target URL sync",
    "nodes": [
