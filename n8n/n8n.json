      },
      {
        "parameters": {
          "resource": "message",
          "guildId": { "__rl": true, "value": "1066890817425387581", "mode": "id" },
          "channelId": { "__rl": true, "value": "1514424075282550916", "mode": "list", "cachedResultName": "gamers-lab-monitor" },
