  {
    "name": "Workflow F — Scheduled one-off surge events",
    "nodes": [
      {
        "parameters": {
          "httpMethod": "POST",
          "path": "schedule-surge",
          "responseMode": "responseNode",
          "options": {}
        },
        "id": "schedule-surge-webhook", "name": "Schedule surge webhook",
        "type": "n8n-nodes-base.webhook", "typeVersion": 1, "position": [240, 300], "webhookId": "schedule-surge"
      },
      {
        "parameters": {
          "jsCode": "// Expects: { scheduledAt: '2026-06-15T14:00:00+10:00', label: 'itch launch event' }\nconst { scheduledAt, label } = $input.first().json.body;\nif (!scheduledAt) throw new Error('scheduledAt is required (ISO 8601)');\n\nconst fireAt = new Date(scheduledAt);\nconst now = new Date();\nconst delayMs = fireAt.getTime() - now.getTime();\n\nif (delayMs < 0) throw new Error('scheduledAt must be in the future');\nif (delayMs > 15 * 24 * 60 * 60 * 1000) throw new Error('scheduledAt must be within 15 days');\n\n// Store the scheduled event in Supabase via output — downstream Postgres node handles insert\nreturn [{ json: { \n  scheduledAt: fireAt.toISOString(),\n  label: label || 'Scheduled surge',\n  delayMs,\n  delayMinutes: Math.round(delayMs / 60000)\n} }];"
        },
        "id": "validate-schedule", "name": "Validate schedule",
        "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [460, 300]
      },
      {
        "parameters": {
          "operation": "insert",
          "schema": { "__rl": true, "value": "public", "mode": "list" },
          "table": { "__rl": true, "value": "scheduled_surges", "mode": "list", "cachedResultName": "scheduled_surges" },
          "dataMode": "defineBelow",
          "valuesToSend": {
            "values": [
              { "column": "scheduled_at", "value": "={{ $json.scheduledAt }}" },
              { "column": "label", "value": "={{ $json.label }}" },
              { "column": "status", "value": "pending" },
              { "column": "created_at", "value": "={{ new Date().toISOString() }}" }
            ]
          },
          "options": {}
        },
        "id": "save-surge-event", "name": "Save surge event",
        "type": "n8n-nodes-base.postgres", "typeVersion": 2, "position": [680, 300],
        "credentials": { "postgres": { "id": "feCyf8b8GoMyHCPS", "name": "Postgres GamersLab" } }
      },
      {
        "parameters": {
          "resource": "message",
          "guildId": { "__rl": true, "value": "1066890817425387581", "mode": "id" },
          "channelId": { "__rl": true, "value": "1514424075282550916", "mode": "list", "cachedResultName": "gamers-lab-monitor" },
          "content": "=📅 **Surge event scheduled**\n\n**Label:** {{ $json.label }}\n**Fires at:** {{ $json.scheduledAt }}\n**In:** {{ $json.delayMinutes }} minutes",
          "options": {}
        },
        "id": "confirm-discord", "name": "Confirm Discord",
        "type": "n8n-nodes-base.discord", "typeVersion": 2, "position": [900, 300],
        "credentials": { "discordBotApi": { "id": "TjYM6pZNQ2PGSVmG", "name": "Discord Bot GamersLab" } }
      },
      {
        "parameters": { "respondWith": "json", "responseBody": "={{ JSON.stringify({ scheduled: true, scheduledAt: $json.scheduledAt, label: $json.label, delayMinutes: $json.delayMinutes }) }}", "options": {} },
        "id": "respond-schedule", "name": "Respond",
        "type": "n8n-nodes-base.respondToWebhook", "typeVersion": 1, "position": [1100, 300]
      }
    ],
    "connections": {
      "Schedule surge webhook": { "main": [[{ "node": "Validate schedule", "type": "main", "index": 0 }]] },
      "Validate schedule": { "main": [[{ "node": "Save surge event", "type": "main", "index": 0 }]] },
      "Save surge event": { "main": [[{ "node": "Confirm Discord", "type": "main", "index": 0 }]] },
      "Confirm Discord": { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
    },
    "settings": { "executionOrder": "v1" }
  },
  {
    "name": "Workflow G — Execute scheduled surge events",
    "nodes": [
      {
        "parameters": { "rule": { "interval": [{ "field": "minutes", "minutesInterval": 1 }] } },
        "id": "poll-schedule", "name": "Poll schedule",
        "type": "n8n-nodes-base.scheduleTrigger", "typeVersion": 1, "position": [240, 300]
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT id, scheduled_at, label FROM scheduled_surges\nWHERE status = 'pending'\nAND scheduled_at <= now() + interval '1 minute'\nAND scheduled_at >= now() - interval '5 minutes'\nORDER BY scheduled_at ASC\nLIMIT 5",
          "options": {}
        },
        "id": "check-due", "name": "Check due events",
        "type": "n8n-nodes-base.postgres", "typeVersion": 2, "position": [460, 300],
        "credentials": { "postgres": { "id": "feCyf8b8GoMyHCPS", "name": "Postgres GamersLab" } }
      },
      {
        "parameters": {
          "conditions": { "number": [{ "value1": "={{ $items().length }}", "operation": "larger", "value2": 0 }] }
        },
        "id": "any-due", "name": "Any due?",
        "type": "n8n-nodes-base.if", "typeVersion": 1, "position": [680, 300]
      },
      {
        "parameters": {
          "resource": "workflowDispatch",
          "owner": "={{ $env.GITHUB_REPO_OWNER }}",
          "repository": "={{ $env.GITHUB_REPO_NAME }}",
          "workflowId": "monitor.yml", "ref": "main",
          "additionalFields": { "inputs": { "inputsUi": { "inputValues": [{ "name": "mode", "value": "surge" }, { "name": "regions", "value": "us-east,eu-west,ap-southeast,sa-east,me-south,af-south" }] } } }
        },
        "id": "fire-surge", "name": "Fire surge",
        "type": "n8n-nodes-base.github", "typeVersion": 1, "position": [900, 220],
        "credentials": { "githubApi": { "id": "QYTeIJkdqrhQltwn", "name": "GitHub DeveloperAlly" } }
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "UPDATE scheduled_surges SET status = 'fired', fired_at = now() WHERE id = {{ $json.id }}",
          "options": {}
        },
        "id": "mark-fired", "name": "Mark fired",
        "type": "n8n-nodes-base.postgres", "typeVersion": 2, "position": [1120, 220],
        "credentials": { "postgres": { "id": "feCyf8b8GoMyHCPS", "name": "Postgres GamersLab" } }
      },
      {
        "parameters": {
          "resource": "message",
          "guildId": { "__rl": true, "value": "1066890817425387581", "mode": "id" },
          "channelId": { "__rl": true, "value": "1514424075282550916", "mode": "list", "cachedResultName": "gamers-lab-monitor" },
          "content": "=⚡ **Scheduled surge fired**\n\n**Event:** {{ $json.label }}\n**Scheduled for:** {{ $json.scheduled_at }}\n\nSurge test running across all 6 regions now.",
          "options": {}
        },
        "id": "fire-discord", "name": "Notify Discord",
        "type": "n8n-nodes-base.discord", "typeVersion": 2, "position": [1340, 220],
        "credentials": { "discordBotApi": { "id": "TjYM6pZNQ2PGSVmG", "name": "Discord Bot GamersLab" } }
      }
    ],
    "connections": {
      "Poll schedule": { "main": [[{ "node": "Check due events", "type": "main", "index": 0 }]] },
      "Check due events": { "main": [[{ "node": "Any due?", "type": "main", "index": 0 }]] },
      "Any due?": { "main": [[{ "node": "Fire surge", "type": "main", "index": 0 }], []] },
      "Fire surge": { "main": [[{ "node": "Mark fired", "type": "main", "index": 0 }]] },
      "Mark fired": { "main": [[{ "node": "Notify Discord", "type": "main", "index": 0 }]] }
    },
    "settings": { "executionOrder": "v1" }
  }
]
