[
  {
    "name": "Workflow A — Scheduled monitor",
    "nodes": [
      {
        "parameters": {
          "rule": {
            "interval": [{ "field": "minutes", "minutesInterval": 5 }]
          }
        },
        "id": "schedule-trigger",
        "name": "Schedule Trigger",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1,
        "position": [240, 300]
      },
      {
        "parameters": {
          "jsCode": "// ~30% fire rate — random interval effect\nif (Math.random() > 0.3) { return []; }\nreturn [{ json: { proceed: true } }];"
        },
        "id": "random-gate",
        "name": "Random gate",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [460, 300]
      },
      {
        "parameters": {
          "resource": "workflowDispatch",
          "owner": "={{ $env.GITHUB_REPO_OWNER }}",
          "repository": "={{ $env.GITHUB_REPO_NAME }}",
          "workflowId": "monitor.yml",
          "ref": "main",
          "additionalFields": {
            "inputs": {
              "inputsUi": {
                "inputValues": [
                  { "name": "mode", "value": "standard" }
                ]
              }
            }
          }
        },
        "id": "dispatch-standard",
        "name": "Dispatch standard run",
        "type": "n8n-nodes-base.github",
        "typeVersion": 1,
        "position": [680, 300],
        "credentials": {
          "githubApi": { "id": "QYTeIJkdqrhQltwn", "name": "GitHub DeveloperAlly" }
        }
      }
    ],
    "connections": {
      "Schedule Trigger": { "main": [[{ "node": "Random gate", "type": "main", "index": 0 }]] },
      "Random gate": { "main": [[{ "node": "Dispatch standard run", "type": "main", "index": 0 }]] }
    },
    "settings": { "executionOrder": "v1" }
  },
  {
    "name": "Workflow B — Campaign surge webhook",
    "nodes": [
      {
        "parameters": {
          "httpMethod": "POST",
          "path": "surge",
          "responseMode": "responseNode",
          "options": {}
        },
        "id": "surge-webhook",
        "name": "Surge webhook",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [240, 300],
        "webhookId": "surge"
      },
      {
        "parameters": {
          "resource": "workflowDispatch",
          "owner": "={{ $env.GITHUB_REPO_OWNER }}",
          "repository": "={{ $env.GITHUB_REPO_NAME }}",
          "workflowId": "monitor.yml",
          "ref": "main",
          "additionalFields": {
            "inputs": {
              "inputsUi": {
                "inputValues": [
                  { "name": "mode", "value": "surge" },
                  { "name": "regions", "value": "us-east,eu-west,ap-southeast,sa-east,me-south,af-south" }
                ]
              }
            }
          }
        },
        "id": "dispatch-surge",
        "name": "Dispatch surge run",
        "type": "n8n-nodes-base.github",
        "typeVersion": 1,
        "position": [460, 300],
        "credentials": {
          "githubApi": { "id": "QYTeIJkdqrhQltwn", "name": "GitHub DeveloperAlly" }
        }
      },
      {
        "parameters": {
          "respondWith": "json",
          "responseBody": "={ \"triggered\": true }",
          "options": {}
        },
        "id": "respond",
        "name": "Respond",
        "type": "n8n-nodes-base.respondToWebhook",
        "typeVersion": 1,
        "position": [680, 300]
      }
    ],
    "connections": {
      "Surge webhook": { "main": [[{ "node": "Dispatch surge run", "type": "main", "index": 0 }]] },
      "Dispatch surge run": { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
    },
    "settings": { "executionOrder": "v1" }
  },
  {
    "name": "Workflow C — Failure alerting (Discord)",
    "nodes": [
      {
        "parameters": {
          "rule": { "interval": [{ "field": "minutes", "minutesInterval": 15 }] }
        },
        "id": "alert-schedule",
        "name": "Alert schedule",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1,
        "position": [240, 300]
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT region, ttfb_ms, cf_colo, checked_at FROM monitor_results WHERE checked_at > now() - interval '30 minutes' AND status = 0 ORDER BY checked_at DESC",
          "options": {}
        },
        "id": "check-failures",
        "name": "Check for failures",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2,
        "position": [460, 300],
        "credentials": { "postgres": { "id": "feCyf8b8GoMyHCPS", "name": "Postgres GamersLab" } }
      },
      {
        "parameters": {
          "conditions": {
            "number": [{ "value1": "={{ $items().length }}", "operation": "larger", "value2": 0 }]
          }
        },
        "id": "if-failures",
        "name": "Any failures?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 1,
        "position": [680, 300]
      },
      {
        "parameters": {
          "resource": "message",
          "guildId": { "__rl": true, "value": "1066890817425387581", "mode": "id" },
          "channelId": { "__rl": true, "value": "1514424075282550916", "mode": "list", "cachedResultName": "gamers-lab-monitor" },
          "content": "=🚨 **Geo monitor failure**\n\n**Region:** {{ $json.region }}\n**TTFB:** {{ $json.ttfb_ms }}ms\n**PoP:** {{ $json.cf_colo }}\n**Time:** {{ $json.checked_at }}",
          "options": {}
        },
        "id": "discord-alert",
        "name": "Send a message",
        "type": "n8n-nodes-base.discord",
        "typeVersion": 2,
        "position": [900, 220],
        "credentials": { "discordBotApi": { "id": "TjYM6pZNQ2PGSVmG", "name": "Discord Bot GamersLab" } }
      }
    ],
    "connections": {
      "Alert schedule": { "main": [[{ "node": "Check for failures", "type": "main", "index": 0 }]] },
      "Check for failures": { "main": [[{ "node": "Any failures?", "type": "main", "index": 0 }]] },
      "Any failures?": { "main": [[{ "node": "Send a message", "type": "main", "index": 0 }], []] }
    },
    "settings": { "executionOrder": "v1" }
  },
  {
    "name": "Workflow D — Target URL sync",
    "nodes": [
      {
        "parameters": {
          "httpMethod": "POST",
          "path": "update-target",
          "responseMode": "responseNode",
          "options": {}
        },
        "id": "target-webhook",
        "name": "Target webhook",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [240, 300],
        "webhookId": "update-target"
      },
      {
        "parameters": {
          "jsCode": "const { url, name } = $input.first().json.body;\nif (!url) throw new Error('url is required');\nreturn [{ json: { url, name: name || url, set_at: new Date().toISOString(), active: true } }];"
        },
        "id": "validate-url",
        "name": "Validate URL",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [460, 300]
      },
      {
        "parameters": {
          "operation": "insert",
          "schema": { "__rl": true, "value": "public", "mode": "list" },
          "table": { "__rl": true, "value": "targets", "mode": "list", "cachedResultName": "targets" },
          "dataMode": "autoMapInputData",
          "options": {}
        },
        "id": "save-to-supabase",
        "name": "Save to Supabase",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2,
        "position": [680, 300],
        "credentials": { "postgres": { "id": "feCyf8b8GoMyHCPS", "name": "Postgres GamersLab" } }
      },
      {
        "parameters": {
          "resource": "message",
          "guildId": { "__rl": true, "value": "1066890817425387581", "mode": "id" },
          "channelId": { "__rl": true, "value": "1514424075282550916", "mode": "list", "cachedResultName": "gamers-lab-monitor" },
          "content": "=🎯 **Monitor target updated**\n\n**URL:** {{ $json.url }}\n**Name:** {{ $json.name }}",
          "options": {}
        },
        "id": "notify-discord",
        "name": "Notify Discord",
        "type": "n8n-nodes-base.discord",
        "typeVersion": 2,
        "position": [900, 300],
        "credentials": { "discordBotApi": { "id": "TjYM6pZNQ2PGSVmG", "name": "Discord Bot GamersLab" } }
      },
      {
        "parameters": {
          "respondWith": "json",
          "responseBody": "={ \"updated\": true }",
          "options": {}
        },
        "id": "respond-target",
        "name": "Respond",
        "type": "n8n-nodes-base.respondToWebhook",
        "typeVersion": 1,
        "position": [1100, 300]
      }
    ],
    "connections": {
      "Target webhook": { "main": [[{ "node": "Validate URL", "type": "main", "index": 0 }]] },
      "Validate URL": { "main": [[{ "node": "Save to Supabase", "type": "main", "index": 0 }]] },
      "Save to Supabase": { "main": [[{ "node": "Notify Discord", "type": "main", "index": 0 }]] },
      "Notify Discord": { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
    },
    "settings": { "executionOrder": "v1" }
  }
]
